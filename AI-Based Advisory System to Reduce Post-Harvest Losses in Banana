lly yellow with brown sugar spots. Soft texture, high sugar content, aromatic.\")\n","        print(\"Uses: Best for eating fresh as a snack, in fruit salads, or smoothies.\")\n","\n","    elif stage == \"over_ripe\":\n","        print(\"Characteristics: Almost entirely brown/dark brown. Extremely soft and very sweet.\")\n","        print(\"Uses: Excellent for baking (banana bread, muffins) and blending into smoothies or pancakes due to high sugar concentration.\")"]},{"cell_type":"code","source":["# 🔍 Prediction Function\n","def predict_image(img_path):\n","    img = load_img(img_path, target_size=(128,128))\n","    img_array = img_to_array(img)/255.0\n","    img_array = np.expand_dims(img_array, axis=0)\n","\n","    pred = model.predict(img_array)\n","    idx = np.argmax(pred)\n","    confidence = np.max(pred)\n","\n","    stage = class_names[idx]\n","\n","    print(\"Stage:\", stage)\n","    print(\"Confidence:\", round(float(confidence), 3))\n","    print(\"Advice:\", advisory(stage))\n"],"metadata":{"id":"TBW9Kisd2A2H","executionInfo":{"status":"ok","timestamp":1776352543519,"user_tz":-330,"elapsed":51,"user":{"displayName":"group7","userId":"04596682978340426572"}}},"execution_count":13,"outputs":[]},{"cell_type":"code","execution_count":19,"metadata":{"id":"BtJ0XbyquGyT","outputId":"ee0d07e7-341f-4ef7-a4e3-3aff79d5afa3","colab":{"base_uri":"https://localhost:8080/","height":197},"executionInfo":{"status":"ok","timestamp":1776354209642,"user_tz":-330,"elapsed":32632,"user":{"displayName":"group7","userId":"04596682978340426572"}}},"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","     <input type=\"file\" id=\"files-d7188a01-d813-4633-bb50-53cf214f5f07\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-d7188a01-d813-4633-bb50-53cf214f5f07\">\n","      Upload widget is only available when the cell has been executed in the\n","      current b